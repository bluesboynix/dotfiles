### --- PATH Setup with Deduplication ---
remove_path_duplicates() {
  local OLD_PATH="$1"
  local NEW_PATH=""
  local IFS=':'
  declare -A SEEN
  for DIR in $OLD_PATH; do
    [[ -n "$DIR" && -z "${SEEN[$DIR]}" ]] && NEW_PATH+="$DIR:" && SEEN["$DIR"]=1
  done
  echo "${NEW_PATH%:}"
}

# Explicit priority path order
DESIRED_PATH="$HOME/.local/bin:/bin:/usr/bin:/usr/local/bin:/sbin:/usr/sbin"
# Combine and deduplicate
export PATH=$(remove_path_duplicates "$DESIRED_PATH:$PATH")


### --- Smart TERM Setup (Local, SSH, Tmux, Modern) ---
set_term_if_supported() {
  local term=$1
  infocmp "$term" >/dev/null 2>&1 && export TERM="$term" && return 0
  return 1
}

set_best_term() {
  case "$TERM_PROGRAM" in
    "Kitty")      set_term_if_supported "xterm-kitty" && return;;
    "WezTerm")    set_term_if_supported "wezterm" && return;;
  esac

  [[ -n "$FOOT" || "$TERM" == "foot" ]] && set_term_if_supported "foot" && return
  [[ "$TERM" == *"kitty"* ]]            && set_term_if_supported "xterm-kitty" && return
  [[ -n "$TMUX" ]]                      && set_term_if_supported "screen-256color" && return
  set_term_if_supported "xterm-256color" || set_term_if_supported "xterm" || export TERM="dumb"
}

set_best_term


